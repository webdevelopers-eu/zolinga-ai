{
  "name": "Zolinga AI",
  "version": "1.5",
  "description": "AI power tools and services.",
  "authors": [
    "Daniel Sevcik <danny@zolinga.net>"
  ],

  "attributes": {},

  "listen": [
    {
      "description": "AI service.",
      "service": "ai",
      "class": "\\Zolinga\\AI\\Service\\AiService",
      "origin": [
        "internal"
      ]
    },
    {
      "description": "CMS page menu.",
      "event": "cms:content:ai-text",
      "class": "\\Zolinga\\AI\\Elements\\AiTextElement",
      "method": "onAiTextElement",
      "origin": [
        "internal"
      ]
    },
    {
      "description": "CLI command to query backends and process AI prompt requests.",
      "event": "ai:generate",
      "class": "\\Zolinga\\AI\\Service\\AiGenerator",
      "method": "onGenerate",
      "origin": [
        "cli"
      ]
    },
    {
      "description": "Save AI output as an article.",
      "event": "ai:article:generated",
      "class": "\\Zolinga\\AI\\Elements\\AiTextElement",
      "method": "onGenerateArticle",
      "origin": [
        "internal"
      ]
    },
    {
      "description": "Update article meta data after generation.",
      "event": "ai:meta:generated",
      "class": "\\Zolinga\\AI\\Elements\\AiTextElement",
      "method": "onGenerateMeta",
      "origin": [
        "internal"
      ]
    }
  ],

  "emit": [
    {
      "event": "ai:article:generated",
      "description": "Dispatched when an AI-generated article is ready (callback from promptAsync).",
      "class": "\\Zolinga\\AI\\Events\\AiEvent",
      "origin": ["internal"]
    },
    {
      "event": "ai:text:generated",
      "description": "Dispatched when an AI text is created or updated in aiTexts table.",
      "class": "\\Zolinga\\System\\Events\\RequestEvent",
      "origin": ["internal"]
    }
  ],

  "autoload": {
    "Zolinga\\AI\\": "src/"
  },

  "dependencies": [
    "zolinga-db"
  ],

  "config": {
    "ai": {
      "log": false,
      "systemPrompt": "You are an exceptionally talented copywriter.",
      "backends": {
        "default": {
          "type": "ollama",
          "url": "http://login:password@127.0.0.1:3000/api",
          "model": "llama3.2:1b",
          "replace": [{"search": "/^.*?<\\/think>\\s*/s", "replace": ""}],
          "systemPrompt": false,
          "think": false,
          "options": [],
          "concurrency": 1
        }
      }
    }
  }
}